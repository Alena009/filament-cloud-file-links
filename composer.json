{
    "name": "alena009/filament-cloud-file-links",
    "description": "Filament form field for cloud file links (name + URL), KeyValue-compatible array storage",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "filament",
        "laravel",
        "forms",
        "cloud",
        "links",
        "key-value"
    ],
    "authors": [
        {
            "name": "Alena009",
            "email": "dashkoalena@gmail.com"
        }
    ],
    "homepage": "https://github.com/Alena009/filament-cloud-file-links",
    "support": {
        "issues": "https://github.com/Alena009/filament-cloud-file-links/issues",
        "source": "https://github.com/Alena009/filament-cloud-file-links"
    },
    "require": {
        "php": "^8.1",
        "filament/forms": "^3.2 || ^4.0 || ^5.0"
    },
    "autoload": {
        "psr-4": {
            "FilamentCloudFileLinks\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FilamentCloudFileLinks\\CloudFileLinksServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
